# =============================================================================
# RMS - Produzione (cremisi.shop)
# Usato da: docker compose up (root) → Caddy + backend + postgres
# Per sviluppo locale usare: rms-backend/.env + npm run dev (frontend)
# =============================================================================

# Database
DB_USERNAME=postgres
DB_PASSWORD=
DB_DATABASE=rms_db

# Backend
NODE_ENV=production
JWT_SECRET=                 # min 32 caratteri
JWT_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=7d
CORS_ORIGINS=
RATE_LIMIT_TTL=900
RATE_LIMIT_MAX=100
SUPERADMIN_PASSWORD=            # password superadmin al primo avvio

# Caddy (auto_https off — SSL gestito da Cloudflare)
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=8443

# MinIO (object storage per immagini prodotto)
MINIO_ACCESS_KEY=           # utente root MinIO
MINIO_SECRET_KEY=           # password root MinIO (min 8 caratteri)
MINIO_BUCKET=rms-images
MINIO_PUBLIC_BASE_URL=https://cremisi.shop/files
